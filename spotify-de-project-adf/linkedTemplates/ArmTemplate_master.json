{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "spotify-de-project-adf"
		},
		"Spotify_project_ADLS_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'Spotify_project_ADLS'"
		},
		"spotify_project_Azure_SQL_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'spotify_project_Azure_SQL'"
		},
		"Spotify_project_ADLS_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://spotifyprojectadls.dfs.core.windows.net/"
		},
		"spotify_project_Azure_SQL_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "spotifydeproject.database.windows.net"
		},
		"spotify_project_Azure_SQL_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "spotifydeprojectdb"
		},
		"spotify_project_Azure_SQL_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "kevin"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "spotify-de-project-adf_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"Spotify_project_ADLS_accountKey": {
						"value": "[parameters('Spotify_project_ADLS_accountKey')]"
					},
					"spotify_project_Azure_SQL_password": {
						"value": "[parameters('spotify_project_Azure_SQL_password')]"
					},
					"Spotify_project_ADLS_properties_typeProperties_url": {
						"value": "[parameters('Spotify_project_ADLS_properties_typeProperties_url')]"
					},
					"spotify_project_Azure_SQL_properties_typeProperties_server": {
						"value": "[parameters('spotify_project_Azure_SQL_properties_typeProperties_server')]"
					},
					"spotify_project_Azure_SQL_properties_typeProperties_database": {
						"value": "[parameters('spotify_project_Azure_SQL_properties_typeProperties_database')]"
					},
					"spotify_project_Azure_SQL_properties_typeProperties_userName": {
						"value": "[parameters('spotify_project_Azure_SQL_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}